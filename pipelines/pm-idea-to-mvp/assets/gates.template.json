{
  "version": "6.2.0",
  "mode": "loop",
  "stages": {
    "brief": { "status": "pending", "checkpoint": "auto", "min_lines": 20 },
    "align": { "status": "pending", "gate": "G1", "checkpoint": "auto", "debate_required": true, "min_lines": 50 },
    "research": { "status": "pending", "checkpoint": "auto", "min_urls": 5, "min_lines": 50 },
    "analysis": { "status": "pending", "checkpoint": "auto", "min_lines": 100 },
    "spec": { "status": "pending", "gate": "G2", "checkpoint": "auto", "debate_required": true, "min_lines": 50 },
    "mvp": {
      "status": "pending",
      "gate": "G3",
      "checkpoint": "auto",
      "runtime_required": true,
      "goals_required": true,
      "inner_loop": {
        "max_iterations": 3,
        "feedback_signals": ["test", "build", "lint"],
        "prerequisites": ["goals/mvp.yaml", "harness-rules.yaml"]
      }
    },
    "ship": {
      "status": "pending",
      "checkpoint": "human",
      "runtime_required": true,
      "goals_required": true,
      "runbook_sections": ["deploy", "rollback", "monitor"],
      "pre_gates": ["infra-ready"]
    },
    "operate": { "status": "pending", "checkpoint": "auto", "required_file": "07-ops-notes.md", "min_lines": 20 },
    "grow": { "status": "pending", "checkpoint": "auto", "min_lines": 30 },
    "retro": {
      "status": "pending",
      "checkpoint": "auto",
      "goals_required": true,
      "required_sections": ["metrics", "iteration_analysis"],
      "min_lines": 50
    }
  },
  "gates": {
    "infra-ready": {
      "description": "Infrastructure pre-flight checks before deployment",
      "checks": [
        {"tool": "ssh_probe", "scope": "all", "description": "All target servers SSH reachable"},
        {"tool": "git_remote_check", "description": "Git push reachable and token valid"},
        {"tool": "infra_health_check", "description": "Local Gateway healthy (source/venv/config)"}
      ],
      "on_fail": "auto-fix Level 1 -> retry -> if still fail, report to user and block ship"
    }
  },
  "v6.2_enforcements": {
    "mandatory_runtime_stages": ["mvp", "ship"],
    "mandatory_goal_stages": ["mvp", "ship", "retro"],
    "mandatory_docs_hygiene_stages": ["align", "analysis", "spec", "mvp", "ship"],
    "debate_required_stages": ["align", "spec"]
  }
}
