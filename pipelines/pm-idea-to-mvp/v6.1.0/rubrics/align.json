{
  "stage": "align",
  "description": "L1 rubric — idea alignment quality",
  "checks": [
    {"id": "problem_stated", "file": "00-brief.md", "any_of": ["问题", "problem", "痛点", "job-to-be-done"], "message": "Brief must state the problem"},
    {"id": "success_metric", "file": "00-brief.md", "any_of": ["成功", "success", "metric", "指标"], "message": "Brief must mention success metrics"},
    {"id": "glossary_rich", "file": "CONTEXT.md", "min_table_rows": 3, "message": "CONTEXT glossary needs ≥3 terms"},
    {"id": "no_tbd_brief", "file": "00-brief.md", "forbidden": ["TBD", "待定"], "message": "No TBD in brief"},
    {"id": "assumptions", "file": "00-brief.md", "any_of": ["假设", "assumption"], "message": "List explicit assumptions"},
    {"id": "chinese_primary", "file": "00-brief.md", "any_of": ["问题", "用户", "目标", "约束", "假设"], "message": "Brief should be primarily Chinese"},
    {"id": "context_chinese", "file": "CONTEXT.md", "any_of": ["术语", "用户", "问题", "glossary"], "message": "CONTEXT should use Chinese headings/terms"}
  ]
}
